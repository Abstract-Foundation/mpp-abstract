{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": false,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "paths": {
      "mppx-abstract": ["../../packages/mppx-abstract/src/index.ts"],
      "mppx-abstract/server": ["../../packages/mppx-abstract/src/server/index.ts"],
      "mppx-abstract/client": ["../../packages/mppx-abstract/src/client/index.ts"]
    }
  },
  "include": ["src/**/*"]
}
